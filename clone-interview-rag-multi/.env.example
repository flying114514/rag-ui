# =====================================
# AI Interview Platform - .env Template
# 复制本文件为 .env 并填写真实值
# =====================================

# -------------------------------------
# 1) AI 主模型（OpenAI 兼容）
# -------------------------------------
# 示例1：Gemini OpenAI compatible
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AI_MODEL=gemini-2.0-flash
# AI_API_KEY=your_gemini_api_key

# 示例2：OpenRouter（推荐做线上兜底）
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openai/gpt-4o-mini
# AI_API_KEY=your_openrouter_api_key

# 结构化输出重试（可选）
APP_AI_STRUCTURED_MAX_ATTEMPTS=2
APP_AI_STRUCTURED_INCLUDE_LAST_ERROR=true

# OpenRouter fallback（可选，若主模型不是 OpenRouter 可开启）
APP_AI_FALLBACK_OPENROUTER_ENABLED=true
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# -------------------------------------
# 2) 面试参数
# -------------------------------------
APP_INTERVIEW_FOLLOW_UP_COUNT=1
APP_INTERVIEW_EVALUATION_BATCH_SIZE=8
APP_INTERVIEW_EVALUATION_SCORE_FRIENDLY_BOOST=6

# -------------------------------------
# 3) 语音（Deepgram，可选）
# -------------------------------------
APP_INTERVIEW_MEDIA_TRANSCRIPTION_ENABLED=true
APP_INTERVIEW_MEDIA_TRANSCRIPTION_PROVIDER=deepgram
APP_INTERVIEW_MEDIA_TRANSCRIPTION_URL=https://api.deepgram.com/v1/listen
APP_INTERVIEW_MEDIA_TRANSCRIPTION_MODEL=nova-2
APP_INTERVIEW_MEDIA_TRANSCRIPTION_API_KEY=
APP_INTERVIEW_MEDIA_TRANSCRIPT_REFINEMENT_ENABLED=true
APP_INTERVIEW_MEDIA_REALTIME_ALLOW_DIRECT_KEY_FALLBACK=false

APP_INTERVIEW_MEDIA_TTS_ENABLED=true
APP_INTERVIEW_MEDIA_TTS_PROVIDER=deepgram
APP_INTERVIEW_MEDIA_TTS_URL=https://api.deepgram.com/v1/speak
APP_INTERVIEW_MEDIA_TTS_API_KEY=
APP_INTERVIEW_MEDIA_TTS_VOICE_ID=aura-orion-en
APP_INTERVIEW_MEDIA_TTS_VOICE_ID_ZH=aura-orion-en
APP_INTERVIEW_MEDIA_TTS_LANGUAGE_ZH=zh-CN

# -------------------------------------
# 4) 基础设施（本地 docker-compose 默认值）
# -------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=interview_guide

REDIS_HOST=localhost
REDIS_PORT=6379

APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=minioadmin
APP_STORAGE_SECRET_KEY=minioadmin
APP_STORAGE_BUCKET=interview-guide
APP_STORAGE_REGION=us-east-1

# -------------------------------------
# 5) 前端跨域（部署时务必改成你的域名）
# -------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:80,https://www.nailong88.online,https://nailong88.online

# -------------------------------------
# 6) 本地文件目录
# -------------------------------------
APP_RESUME_UPLOAD_DIR=./data/uploads
